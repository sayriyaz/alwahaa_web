{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/contact.php", "destination": "/contact", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/blog-post.html", "destination": "/blog/mainland-company-dubai", "permanent": true },
    { "source": "/golden-visa-uae.html", "destination": "/blog/uae-golden-visa", "permanent": true },
    { "source": "/free-zone-vs-mainland-dubai.html", "destination": "/blog/free-zone-vs-mainland-dubai", "permanent": true },
    { "source": "/document-attestation-uae.html", "destination": "/blog/document-attestation-uae", "permanent": true },
    { "source": "/corporate-tax-vat-uae.html", "destination": "/blog/corporate-tax-vat-uae", "permanent": true },
    { "source": "/family-visa-emirates-id-uae.html", "destination": "/blog/family-visa-emirates-id-uae", "permanent": true },
    { "source": "/pro-services-dubai.html", "destination": "/blog/pro-services-dubai", "permanent": true },
    { "source": "/v2/index.html", "destination": "/", "permanent": true },
    { "source": "/v2/about.html", "destination": "/about", "permanent": true },
    { "source": "/v2/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/v2/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/v2/contact.php", "destination": "/contact", "permanent": true },
    { "source": "/v2/blog-post.html", "destination": "/blog/mainland-company-dubai", "permanent": true },
    { "source": "/v2/golden-visa-uae.html", "destination": "/blog/uae-golden-visa", "permanent": true },
    { "source": "/v2/free-zone-vs-mainland-dubai.html", "destination": "/blog/free-zone-vs-mainland-dubai", "permanent": true },
    { "source": "/v2/document-attestation-uae.html", "destination": "/blog/document-attestation-uae", "permanent": true },
    { "source": "/v2/corporate-tax-vat-uae.html", "destination": "/blog/corporate-tax-vat-uae", "permanent": true },
    { "source": "/v2/family-visa-emirates-id-uae.html", "destination": "/blog/family-visa-emirates-id-uae", "permanent": true },
    { "source": "/v2/pro-services-dubai.html", "destination": "/blog/pro-services-dubai", "permanent": true }
  ],
  "rewrites": [
    { "source": "/assets/:path*", "destination": "/v2/assets/:path*" },
    { "source": "/", "destination": "/v2/index.html" },
    { "source": "/about", "destination": "/v2/about.html" },
    { "source": "/blog", "destination": "/v2/blog.html" },
    { "source": "/contact", "destination": "/v2/contact.html" },
    { "source": "/robots.txt", "destination": "/v2/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/v2/sitemap.xml" },
    { "source": "/llms.txt", "destination": "/v2/llms.txt" },
    { "source": "/blog/mainland-company-dubai", "destination": "/v2/blog-post.html" },
    { "source": "/blog/uae-golden-visa", "destination": "/v2/golden-visa-uae.html" },
    { "source": "/blog/free-zone-vs-mainland-dubai", "destination": "/v2/free-zone-vs-mainland-dubai.html" },
    { "source": "/blog/document-attestation-uae", "destination": "/v2/document-attestation-uae.html" },
    { "source": "/blog/corporate-tax-vat-uae", "destination": "/v2/corporate-tax-vat-uae.html" },
    { "source": "/blog/family-visa-emirates-id-uae", "destination": "/v2/family-visa-emirates-id-uae.html" },
    { "source": "/blog/pro-services-dubai", "destination": "/v2/pro-services-dubai.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
